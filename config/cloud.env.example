# Connection profile: TEMPORAL CLOUD (annotated template).
#
# This is a reference for the fields a Cloud profile needs. The live profiles the
# tooling actually sources live in the hardened, git-ignored secrets dir:
#   .secrets/keys/cloud-nonprod.env   (sourced by `just up-cloud`)
#   .secrets/keys/cloud-prod.env      (sourced by `just up-cloud-prod`)
#
# Normally you DERIVE these from the Cloud Terraform layer's outputs rather than
# hand-editing — see README.md "Getting started" step 5 and
# deploy/terraform/layers/cloud/README.md. Workers/apps run locally (Compose or kind);
# only the Temporal backend is Cloud.

# --- Auth: choose ONE ---

# (a) API key (simplest, and the default for this repo's Cloud namespaces).
#     API-key auth REQUIRES the *regional* endpoint, NOT the namespace endpoint
#     (<ns>.<account>.tmprl.cloud:7233 rejects API keys with `tls: certificate required`).
#     The cloud layer's `endpoints` output already returns the regional form.
TEMPORAL_ADDRESS=<region>.<cloud>.api.temporal.io:7233   # e.g. us-east-1.aws.api.temporal.io:7233
TEMPORAL_NAMESPACE=ziggymart.<account-id>
TEMPORAL_TLS=true
TEMPORAL_API_KEY=                                        # never commit; paste the worker key

# (b) mTLS client certificate (instead of an API key). Uses the NAMESPACE endpoint.
# TEMPORAL_ADDRESS=ziggymart.<account-id>.tmprl.cloud:7233
# TEMPORAL_NAMESPACE=ziggymart.<account-id>
# TEMPORAL_TLS=true
# TEMPORAL_TLS_CLIENT_CERT_PATH=/etc/temporal/tls/client.pem
# TEMPORAL_TLS_CLIENT_KEY_PATH=/etc/temporal/tls/client.key
