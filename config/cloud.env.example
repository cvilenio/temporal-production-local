# Connection profile: TEMPORAL CLOUD. Copy to config/cloud.env (git-ignored) and fill in.
# Workers/apps still run locally on kind; only the Temporal backend is Cloud.

# Endpoint is <namespace>.<account>.tmprl.cloud:7233
TEMPORAL_ADDRESS=ziggymart.<account-id>.tmprl.cloud:7233
TEMPORAL_NAMESPACE=ziggymart.<account-id>
TEMPORAL_TLS=true

# --- Auth: choose ONE ---
# (a) API key (simplest). Do NOT commit the key; load it from guts.<account-id>.txt / a secret.
TEMPORAL_API_KEY=

# (b) mTLS client certificate (instead of an API key)
# TEMPORAL_TLS_CLIENT_CERT_PATH=/etc/temporal/tls/client.pem
# TEMPORAL_TLS_CLIENT_KEY_PATH=/etc/temporal/tls/client.key
