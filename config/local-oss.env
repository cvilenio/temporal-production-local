# Connection profile: LOCAL OSS Temporal server on Docker Compose.
# Sourced by `poe up` so the backend is deterministic regardless of any
# TEMPORAL_* exported in the host shell (e.g. via .envrc/direnv, which targets
# host-direct SDK runs at localhost:7233, NOT the in-container service name).
export TEMPORAL_ADDRESS=temporal:7233
export TEMPORAL_NAMESPACE=ziggymart
export TEMPORAL_TLS=false
export TEMPORAL_API_KEY=
