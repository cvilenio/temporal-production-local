# Connection profile for the kind + self-hosted OSS backend (ADR-0003 / -0005).
# Sourced by `just host-plane-up-oss` and `just switch-backend oss` into the host
# console/visibility stack (docker-compose.yml). Tracked; NO secrets — the OSS
# mTLS material lives in-cluster (cert-manager), and the host console does not
# open a Temporal client on the `oss` backend (its liveness probe is off;
# /architecture reads cluster pod state via kube). See docs/RUNMODES.md.

# Backend-kind descriptor: flips the console to the OSS architecture view + full
# reset semantics, and disables the Cloud liveness probe / Ops API (ADR-0015).
CONSOLE_BACKEND=oss
# Status source stays the kube provider (cluster pods) — the base default on kind.
CONSOLE_SUBSTRATE=kind

# Embedded Temporal Web UI: the frame-stripping viz-proxy in front of the
# in-cluster temporal-web (ADR-0014 pattern), host-published. The console sidebar
# link + /temporal-ui iframe render this.
TEMPORAL_UI_EMBED_URL=http://localhost:8089

# Bare domain namespace (matches the OSS bootstrap Job); no account suffix.
TEMPORAL_NAMESPACE=ziggymart

# Cloud-only knobs stay empty on OSS: no API key, no Ops API observer key, no
# Cloud endpoint. Their absence keeps the sidebar link internal (iframe) and the
# Cloud regions/namespaces inventory off.
TEMPORAL_ADDRESS=
TEMPORAL_TLS=
TEMPORAL_API_KEY=
TEMPORAL_UI_EXTERNAL_URL=
TEMPORAL_CLOUD_OPS_API_KEY=

# Generic domain trigger (Phase B): console reaches kind OSS frontend via host gateway + mTLS.
# The frontend Service is ClusterIP-only; until it exposes NodePort 30723 (kind-config
# hostPort 7233), port-forward for live trigger:
#   kubectl port-forward -n temporal svc/temporal-frontend 17233:7233
# then set TEMPORAL_TRIGGER_ADDRESS=host.docker.internal:17233 (or use host 7233 once
# the chart exposes the NodePort).
DOMAIN_DESCRIPTORS_DIR=/config/domains
TEMPORAL_TRIGGER_ADDRESS=host.docker.internal:7233
TEMPORAL_TRIGGER_TLS=true
TEMPORAL_TRIGGER_TLS_DOMAIN=temporal-frontend.temporal.svc.cluster.local
