# Copy to terraform.tfvars (git-ignored) and adjust. The bootstrap API key is NOT set
# here — export it instead: `export TEMPORAL_CLOUD_API_KEY=...` (or TF_VAR_temporal_cloud_api_key).

# account_id is NOT set here — it is account-identifying. Supply it via
# TF_VAR_account_id by sourcing .secrets/account.env before terraform commands.

# Cloud-ONLY overlay, keyed by DOMAIN (`<domain>`, no environment axis — ADR-0017).
# The SHARED config (retention, search attributes) lives in
# config/temporal/namespaces.yaml and is merged in via locals — do NOT repeat it
# here. To add a business domain, add it to the spec, then add one overlay entry
# below (e.g. `payments`) — each domain gets its own namespace + least-priv SA/key,
# which is what enables Nexus across domains and per-domain auth.
cloud_overlay = {
  "ziggymart" = {
    service_account_name = "orders-workers"
    api_key_display_name = "orders-workers-key"
    api_key_expiry_time  = "2027-06-23T00:00:00Z"
    # create_api_key     = true             # default; false → mint via tcld out-of-band
    # namespace_permission = "write"         # default
    # account_access     = "read"            # default
    # regions            = ["aws-us-east-1"] # default; per-domain multi-region axis
    # Optional dedicated client identity for an in-cluster workflow STARTER (e.g.
    # the orders-api on kind). Omit to run the client on the worker SA instead.
    client_service_account_name = "orders-api"
    client_api_key_display_name = "orders-api-key"
    # create_client_api_key       = true     # default
    # client_namespace_permission = "write"  # default (starter needs write)
    # client_account_access       = "read"   # default
  }

  # "payments" = { service_account_name = "payments-workers", ... }   # a future domain
}
