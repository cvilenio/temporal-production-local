{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "uid": "ziggymart-business",
  "title": "Ziggymart — Business & Custom Metrics",
  "tags": ["ziggymart", "temporal", "demo"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Payments captured (rate/s)  — OTLP push business metric",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(orders_payments_captured_total[5m]))",
          "legendFormat": "payments/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Payment amount p95 (cents)  — OTLP push histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(orders_payment_amount_usd_cents_bucket[5m])))",
          "legendFormat": "p95 amount (cents)"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Workflow steps completed (rate/s by step)  — custom pull metric",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (step) (rate(order_workflow_steps_completed[5m]))",
          "legendFormat": "{{step}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Saga compensations run (rate/s by activity)  — custom pull metric",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (activity) (rate(order_workflow_compensations_run[5m]))",
          "legendFormat": "{{activity}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Payment capture call duration p95 (s)  — operational pull histogram",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(orders_payment_capture_duration_bucket[5m])))",
          "legendFormat": "p95 capture duration"
        }
      ]
    }
  ]
}
