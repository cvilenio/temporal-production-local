{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "uid": "ziggymart-orders-logs",
  "title": "Ziggymart Orders Logs",
  "tags": ["ziggymart", "logs"],
  "schemaVersion": 39,
  "version": 2,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-logs" },
        "query": {
          "refId": "container",
          "editorType": "sql",
          "rawSql": "SELECT DISTINCT ResourceAttributes['k8s.container.name'] AS container FROM default.otel_logs WHERE ResourceAttributes['k8s.namespace.name'] = 'orders' AND container != '' ORDER BY container",
          "queryType": "table",
          "format": 1
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log volume by level",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-logs" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 70, "stacking": { "mode": "normal" } },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-logs" },
          "editorType": "sql",
          "rawSql": "SELECT $__timeInterval(Timestamp) AS time, SeverityText AS level, count() AS count FROM default.otel_logs WHERE $__timeFilter(Timestamp) AND ResourceAttributes['k8s.namespace.name'] = 'orders' AND match(ResourceAttributes['k8s.container.name'], '${container:regex}') GROUP BY time, level ORDER BY time",
          "queryType": "timeseries",
          "format": 1,
          "legendFormat": "{{ level }}"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Orders logs — message (expand a row for the full structured context)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-logs" },
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 7 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-logs" },
          "editorType": "sql",
          "rawSql": "SELECT Timestamp, Body, SeverityText, LogAttributes, ResourceAttributes FROM default.otel_logs WHERE $__timeFilter(Timestamp) AND ResourceAttributes['k8s.namespace.name'] = 'orders' AND match(ResourceAttributes['k8s.container.name'], '${container:regex}') ORDER BY Timestamp DESC LIMIT 1000",
          "queryType": "logs",
          "format": 2
        }
      ]
    }
  ]
}
