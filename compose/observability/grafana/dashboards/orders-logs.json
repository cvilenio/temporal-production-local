{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "uid": "ziggymart-orders-logs",
  "title": "Ziggymart Orders Logs",
  "tags": ["ziggymart", "logs"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({k8s_namespace_name=\"orders\"}, k8s_container_name)",
        "definition": "label_values({k8s_namespace_name=\"orders\"}, k8s_container_name)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log volume by level",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 70, "stacking": { "mode": "normal" } },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (count_over_time({k8s_namespace_name=\"orders\", k8s_container_name=~\"$container\"} [$__auto]))",
          "legendFormat": "{{level}}",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Orders logs — message (expand a row for the full structured context)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 7 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{k8s_namespace_name=\"orders\", k8s_container_name=~\"$container\"}",
          "queryType": "range"
        }
      ]
    }
  ]
}
