{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "uid": "orders-business",
  "title": "Orders Business & Custom Metrics",
  "tags": ["orders", "temporal", "demo"],
  "schemaVersion": 39,
  "version": 3,
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Payments captured (count/interval)  — OTLP push → ClickHouse",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-logs" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-logs" },
          "editorType": "sql",
          "rawSql": "SELECT $__timeInterval(TimeUnix) AS time, sum(Value) AS \"payments captured\" FROM default.otel_metrics_sum WHERE $__timeFilter(TimeUnix) AND MetricName = 'orders.payments_captured' GROUP BY time ORDER BY time",
          "queryType": "timeseries",
          "format": 1,
          "legendFormat": "payments captured"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Avg payment amount (cents)  — OTLP push histogram → ClickHouse",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-logs" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-logs" },
          "editorType": "sql",
          "rawSql": "SELECT $__timeInterval(TimeUnix) AS time, sum(Sum) / nullIf(sum(Count), 0) AS \"avg amount (cents)\" FROM default.otel_metrics_histogram WHERE $__timeFilter(TimeUnix) AND MetricName = 'orders.payment_amount' GROUP BY time ORDER BY time",
          "queryType": "timeseries",
          "format": 1,
          "legendFormat": "avg amount (cents)"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Workflow steps completed (rate/s by step)  — custom pull metric",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-kind" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-kind" },
          "expr": "sum by (step) (rate(order_workflow_steps_completed[5m]))",
          "legendFormat": "{{step}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Saga compensations run (rate/s by activity)  — custom pull metric",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-kind" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-kind" },
          "expr": "sum by (activity) (rate(order_workflow_compensations_run[5m]))",
          "legendFormat": "{{activity}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Payment capture call duration p95 (s)  — operational pull histogram",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus-kind" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-kind" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(orders_payment_capture_duration_bucket[5m])))",
          "legendFormat": "p95 capture duration"
        }
      ]
    }
  ]
}
