    {
      "type": "timeseries",
      "title": "Workflow Task Schedule-to-Start p99",
      "description": "The single best worker-saturation canary. Rising = not enough workflow-task-queue capacity for the load. metric: temporal_workflow_task_schedule_to_start_latency_seconds (OpenMetrics unit suffix; values in seconds)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-kind"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 10
      },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-kind"
          },
          "expr": "histogram_quantile(0.99, sum by (le, task_queue) (rate(temporal_workflow_task_schedule_to_start_latency_seconds_bucket[$rate])))",
          "legendFormat": "{{task_queue}}"
        }
      ]
    },
