    {
      "type": "stat",
      "title": "Workflow Success Rate % (Account-wide)",
      "description": "success / (success + failed + timeout + terminated) * 100. No data until this Namespace has completed Workflow traffic.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-kind"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 12
      },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 99
              },
              {
                "color": "green",
                "value": 99.9
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-kind"
          },
          "expr": "sum(temporal_cloud_v1_workflow_success_count) / (sum(temporal_cloud_v1_workflow_success_count) + sum(temporal_cloud_v1_workflow_failed_count) + sum(temporal_cloud_v1_workflow_timeout_count) + sum(temporal_cloud_v1_workflow_terminate_count)) * 100",
          "legendFormat": "workflow success rate"
        }
      ]
    },
