  "panels": [
    {
      "type": "text",
      "title": "Flow 2 \u2014 Workflow Progress",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "mode": "markdown",
        "content": "\nFrontend operations for **workers polling** for work (`Poll*`) and **completing** it (`Respond*`).\nThis is the server side of worker activity \u2014 pair it with the **Worker Tuning** dashboard for the\nSDK/worker view (slots, sticky cache, schedule-to-start).\n\n> **Caveat:** OSS `service_latency` for `Respond*` **includes** the time the worker is responsible\n> for, so treat the latency below as worker-inclusive.\n"
      }
    },
    {
      "type": "row",
      "title": "Progress \u2014 Respond*",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 2,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Respond* RPS by Operation",
      "description": "",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (operation) (rate(service_requests{operation=~\"RespondWorkflowTaskCompleted|RespondActivityTaskCompleted|RespondWorkflowTaskFailed|RespondActivityTaskFailed|RespondActivityTaskCanceled\"}[$rate]))",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Respond* Errors by Operation",
      "description": "",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
