    {
      "type": "stat",
      "title": "Service Availability % (frontend)",
      "description": "OSS: 100 - errors/requests, rate-based. Cloud: same formula against precomputed v1 counters.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-kind"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 29
      },
      "id": 7,
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-kind"
          },
          "expr": "100 - (sum(rate(service_errors[$rate]) OR on() vector(0)) / sum(rate(service_requests[$rate])) * 100)",
          "legendFormat": "availability (OSS)"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-kind"
          },
          "expr": "100 - ((sum(temporal_cloud_v1_service_error_count) OR on() vector(0)) / sum(temporal_cloud_v1_service_request_count) * 100)",
          "legendFormat": "availability (Cloud)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Instances Up by Job",
      "description": "temporal-server + temporal-sdk + temporal-cloud scrape targets — this already works identically on either backend.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-kind"
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 29
      },
      "id": 8,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-kind"
          },
          "expr": "sum by (job) (up)",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ],
