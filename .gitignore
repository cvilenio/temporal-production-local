# OS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.*
.pytest_cache/
.ruff_cache/

# Rendered from config/temporal/namespaces.yaml by the OSS bootstrap; ephemeral.
config/temporal/.generated/

# Terraform (deploy/terraform)
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
# Saved plan files can embed sensitive planned values
*.plan
*.tfplan

# Secrets / Temporal Cloud credentials (keep out of git).
# Ignore the CONTENTS of .secrets/ but track its README + structure so the layout
# (keys/, terraform/) exists on a fresh clone.
.secrets/**
!.secrets/README.md
!.secrets/keys/
!.secrets/keys/.gitkeep
!.secrets/terraform/
!.secrets/terraform/.gitkeep
*.key
*.pem
*-apikey*
*.tmprl.txt

# IDE
.idea/
.vscode/
*.swp

# Local-only sensitive-marker denylist for the pre-commit hook (never commit)
.githooks/patterns.local
