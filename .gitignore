# OS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.*
.pytest_cache/
.ruff_cache/

# Rendered from config/temporal/namespaces.yaml by the OSS bootstrap; ephemeral.
config/temporal/.generated/
# Rendered from config/dependencies.yaml by render-deps.py; ephemeral.
config/.generated/
# temporal-server wrapper: the vendored upstream subchart (fetched by `helm
# dependency build` at publish time) + the bootstrap spec copied in from the
# generated OSS env. Both ephemeral; Chart.lock IS committed (pins the digest).
deploy/charts/temporal-server/charts/
deploy/charts/temporal-server/files/
# Fetched (pinned + sha256-verified) Headlamp UI plugins; ephemeral artifacts
# pulled by fetch-headlamp-plugins.py. Keep the dir, ignore its contents.
compose/deployment/headlamp/plugins/*
!compose/deployment/headlamp/plugins/.gitkeep

# Fetched (pinned + sha256-verified) Grafana plugins; ephemeral artifacts
# pulled by fetch-grafana-plugins.py. Keep the dir, ignore its contents.
compose/deployment/grafana/plugins/*
!compose/deployment/grafana/plugins/.gitkeep

# Terraform (deploy/terraform)
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
# Saved plan files can embed sensitive planned values
*.plan
*.tfplan

# Secrets / Temporal Cloud credentials (keep out of git).
# Ignore the CONTENTS of .secrets/ but track its README + structure so the layout
# (keys/, terraform/) exists on a fresh clone.
.secrets/**
!.secrets/README.md
!.secrets/keys/
!.secrets/keys/.gitkeep
!.secrets/terraform/
!.secrets/terraform/.gitkeep
*.key
*.pem
*-apikey*
*.tmprl.txt

# IDE
.idea/
.vscode/
*.swp

# Local-only sensitive-marker denylist for the pre-commit hook (never commit)
.githooks/patterns.local
